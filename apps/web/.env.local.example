# ── Supabase ──────────────────────────────────────────────
# Project URL (from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres connection string — use Transaction mode pooler (port 6543) for serverless
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase S3-compatible storage (for LiveKit egress)
# Found in Supabase dashboard → Storage → S3 connection
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_BUCKET=recordings
SUPABASE_S3_REGION=us-east-1

# ── LiveKit ────────────────────────────────────────────────
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# WebSocket URL for your LiveKit Cloud project
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ── Deepgram ──────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Trigger.dev ───────────────────────────────────────────
TRIGGER_SECRET_KEY=your-trigger-secret-key

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cal.com ───────────────────────────────────────────────
CAL_API_KEY=your-cal-api-key

# ── Resend ────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── OAuth ─────────────────────────────────────────────────
# Configure these as OAuth providers in Supabase dashboard → Auth → Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Vercel Cron ───────────────────────────────────────────
# Used to verify cron requests are from Vercel (set in Vercel env vars)
CRON_SECRET=your-random-secret-string

# ── Ops alerts ────────────────────────────────────────────
OPS_ALERT_EMAIL=ops@yourcompany.com
